  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up (alias)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Lenovo\",\n  \"lastName\": \"User\",\n  \"company\": \"Tanga Group\",\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"password\": \"{{password}}\",\n  \"redirectTo\": \"{{redirectTo}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);",
                  "if (data.user && data.user.id) pm.environment.set('userId', data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Sign In (alias)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{loginIdentifier}}\",\n  \"password\": \"{{password}}\",\n  \"redirectTo\": \"{{redirectTo}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signin"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.requiresTwoFactor === true) pm.environment.set('twoFactorToken', data.twoFactorToken);"
                ]
              }
            }
          ]
        },
