{
  "preset": "ts-jest",
  "rootDir": ".",
  "testEnvironment": "node",
  "clearMocks": true,
  "restoreMocks": true,
  "testRegex": "src/.*\\.spec\\.ts$",
  "setupFilesAfterEnv": ["<rootDir>/test/jest.setup.ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.spec.json"
      }
    ]
  }
}
