{
  "name": "rfid-backend",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "test": "jest --config ./jest-unit.json --runInBand",
    "test:watch": "jest --config ./jest-unit.json --watch",
    "test:cov": "jest --config ./jest-unit.json --coverage --runInBand",
    "test:unit": "jest --config ./jest-unit.json --runInBand",
    "test:unit:watch": "jest --config ./jest-unit.json --watch",
    "test:unit:cov": "jest --config ./jest-unit.json --coverage --runInBand",
    "test:e2e": "jest --config ./jest-e2e.json --runInBand --forceExit",
    "test:all": "npm run test && npm run test:e2e",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "mqtt:test:publish": "node scripts/publish-rfid-presence-test.mjs",
    "cleanup:feedback-identifiers": "node -r ts-node/register prisma/cleanup-feedback-identifiers.ts",
    "cleanup:feedback-identifiers:apply": "node -r ts-node/register prisma/cleanup-feedback-identifiers.ts --apply",
    "cleanup:feedback-identifiers:force": "node -r ts-node/register prisma/cleanup-feedback-identifiers.ts --apply --force"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "mqtt": "^5.15.0",
    "ms": "^2.1.3",
    "nodemailer": "^8.0.1",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.13.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^30.2.0",
    "prisma": "^6.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json prisma/seed.ts"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "glob": "^10.5.0",
    "tmp": "^0.2.4",
    "webpack": "^5.104.1"
  }
}
