generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  LOCAL
  GOOGLE
  MAGIC_LINK
}

enum HardwareSystemCode {
  RFID_PRESENCE
  RFID_PORTE
  BIOMETRIE
  FEEDBACK
}

enum DeviceStatus {
  IN_STOCK
  RESERVED
  ASSIGNED
}

enum IdentifierType {
  BADGE
  EMPREINTE
  SERRURE
}

enum IdentifierStatus {
  IN_STOCK
  RESERVED
  ASSIGNED
}

enum FeedbackSentiment {
  NEGATIVE
  NEUTRAL
  POSITIVE
}

enum FeedbackSource {
  BUTTON
  QR
}

enum OrderTargetType {
  DEVICE
  IDENTIFIER_EXTENSION
}

enum OrderStatus {
  CREATED
  COMPLETED
  FAILED
}

enum AllocationStatus {
  RESERVED
  ASSIGNED
  RELEASED
  FAILED
}

enum StockResourceType {
  DEVICE
  IDENTIFIER
}

enum StockMovementAction {
  STOCK_CREATED
  EXTENSION_STOCK_CREATED
  RESERVED
  ASSIGNED
  RELEASED
  CONFIGURED
}

enum OutboxEventType {
  ORDER_ALLOCATED
  STOCK_LOW
  DEVICE_ACTIVATED
  RESERVATION_RELEASED
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
}

model Tenant {
  id               String            @id @default(uuid())
  name             String
  domain           String            @unique
  users            User[]
  roles            Role[]
  orders           Order[]
  outboxEvents     OutboxEvent[]
  webhookEndpoints WebhookEndpoint[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([domain])
  @@map("tenants")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  permissions Json
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([name])
  @@map("roles")
}

model User {
  id                       String         @id @default(uuid())
  name                     String
  email                    String         @unique
  phoneNumber              String?        @unique
  passwordHash             String?
  googleId                 String?        @unique
  provider                 AuthProvider   @default(LOCAL)
  isTwoFactorEnabled       Boolean        @default(false)
  twoFactorSecretEncrypted String?
  twoFactorSecretIv        String?
  twoFactorSecretTag       String?
  twoFactorSecretHash      String?
  roleId                   String
  tenantId                 String
  role                     Role              @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tenant                   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  refreshTokens            RefreshToken[]
  magicLinkTokens          MagicLinkToken[]
  employees                Employee[]        @relation("user_employees")
  serviceAssignments       ServiceAssignment[] @relation("user_service_assignments")
  serviceHistoryEvents     ServiceHistoryEvent[] @relation("user_service_history_events")
  feedbackEvents           FeedbackEvent[]   @relation("user_feedback_events")
  ownedDevices             Device[]          @relation("user_devices")
  createdDevices           Device[]          @relation("admin_created_devices")
  ownedIdentifiers         Identifier[]      @relation("user_identifiers")
  createdIdentifiers       Identifier[]      @relation("admin_created_identifiers")
  orders                   Order[]           @relation("user_orders")
  allocations              Allocation[]      @relation("user_allocations")
  adminActionLogs          AdminActionLog[]  @relation("admin_action_logs")
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([email])
  @@index([phoneNumber])
  @@index([googleId])
  @@index([tenantId, roleId])
  @@map("users")
}

model RefreshToken {
  id                String    @id @default(uuid())
  jti               String    @unique
  tokenHash         String
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model MagicLinkToken {
  id         String   @id @default(uuid())
  jti        String   @unique
  tokenHash  String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("magic_link_tokens")
}

model BusinessSystem {
  id                   String            @id @default(uuid())
  name                 String
  code                 HardwareSystemCode @unique
  hasIdentifiers       Boolean           @default(false)
  identifiersPerDevice Int               @default(0)
  identifierType       IdentifierType?
  deviceUnitPriceCents Int               @default(0)
  extensionUnitPriceCents Int            @default(0)
  currency             String            @default("XOF") @db.VarChar(3)
  lowStockThreshold    Int               @default(5)
  isActive             Boolean           @default(true)
  devices              Device[]
  identifiers          Identifier[]
  orders               Order[]
  stockMovements       StockMovement[]
  outboxEvents         OutboxEvent[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([isActive])
  @@map("business_systems")
}

model Device {
  id                  String          @id @default(uuid())
  systemId            String
  system              BusinessSystem  @relation(fields: [systemId], references: [id], onDelete: Restrict)
  macAddress          String          @unique
  status              DeviceStatus    @default(IN_STOCK)
  ownerId             String?
  owner               User?           @relation("user_devices", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTenantId       String?
  createdById         String?
  createdBy           User?           @relation("admin_created_devices", fields: [createdById], references: [id], onDelete: SetNull)
  warehouseCode       String          @default("MAIN")
  reservedAt          DateTime?
  reservationExpiresAt DateTime?
  identifiers         Identifier[]
  serviceAssignments  ServiceAssignment[] @relation("device_service_assignments")
  serviceHistoryEvents ServiceHistoryEvent[] @relation("device_service_history_events")
  feedbackEvents      FeedbackEvent[] @relation("device_feedback_events")
  allocations         Allocation[]
  stockMovements      StockMovement[]
  outboxEvents        OutboxEvent[]
  configuredName      String?
  configuredLocation  String?
  isConfigured        Boolean         @default(false)
  qrCodeToken         String?         @unique
  qrCodeDataUrl       String?
  assignedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([systemId])
  @@index([status])
  @@index([ownerId])
  @@index([ownerTenantId])
  @@index([warehouseCode])
  @@index([reservationExpiresAt])
  @@index([status, reservationExpiresAt])
  @@index([systemId, status])
  @@index([systemId, warehouseCode, status])
  @@map("devices")
}

model Identifier {
  id                  String           @id @default(uuid())
  systemId            String
  system              BusinessSystem   @relation(fields: [systemId], references: [id], onDelete: Restrict)
  deviceId            String?
  device              Device?          @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  ownerId             String?
  owner               User?            @relation("user_identifiers", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTenantId       String?
  createdById         String?
  createdBy           User?            @relation("admin_created_identifiers", fields: [createdById], references: [id], onDelete: SetNull)
  warehouseCode       String           @default("MAIN")
  reservedAt          DateTime?
  reservationExpiresAt DateTime?
  type                IdentifierType
  physicalIdentifier  String           @unique
  status              IdentifierStatus @default(IN_STOCK)
  allocations         Allocation[]
  serviceAssignment   ServiceAssignment? @relation("identifier_service_assignment")
  serviceHistoryEvents ServiceHistoryEvent[] @relation("identifier_service_history_events")
  stockMovements      StockMovement[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([systemId])
  @@index([status])
  @@index([ownerId])
  @@index([ownerTenantId])
  @@index([deviceId])
  @@index([warehouseCode])
  @@index([reservationExpiresAt])
  @@index([status, reservationExpiresAt])
  @@index([systemId, status])
  @@index([systemId, warehouseCode, status])
  @@index([physicalIdentifier])
  @@map("identifiers")
}

model Employee {
  id                 String               @id @default(uuid())
  ownerId            String
  owner              User                 @relation("user_employees", fields: [ownerId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  normalizedFullName String
  assignments        ServiceAssignment[]  @relation("employee_service_assignments")
  historyEvents      ServiceHistoryEvent[] @relation("employee_service_history_events")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([ownerId])
  @@unique([ownerId, normalizedFullName])
  @@map("employees")
}

model ServiceAssignment {
  id           String          @id @default(uuid())
  ownerId      String
  owner        User            @relation("user_service_assignments", fields: [ownerId], references: [id], onDelete: Cascade)
  module       HardwareSystemCode
  deviceId     String
  device       Device          @relation("device_service_assignments", fields: [deviceId], references: [id], onDelete: Restrict)
  identifierId String          @unique
  identifier   Identifier      @relation("identifier_service_assignment", fields: [identifierId], references: [id], onDelete: Restrict)
  employeeId   String
  employee     Employee        @relation("employee_service_assignments", fields: [employeeId], references: [id], onDelete: Restrict)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([ownerId, module])
  @@index([ownerId, employeeId])
  @@index([deviceId])
  @@index([employeeId])
  @@map("service_assignments")
}

model ServiceHistoryEvent {
  id             String           @id @default(uuid())
  ownerId        String
  owner          User             @relation("user_service_history_events", fields: [ownerId], references: [id], onDelete: Cascade)
  module         HardwareSystemCode
  deviceId       String
  device         Device           @relation("device_service_history_events", fields: [deviceId], references: [id], onDelete: Restrict)
  identifierId   String?
  identifier     Identifier?      @relation("identifier_service_history_events", fields: [identifierId], references: [id], onDelete: SetNull)
  employeeId     String?
  employee       Employee?        @relation("employee_service_history_events", fields: [employeeId], references: [id], onDelete: SetNull)
  employeeName   String
  identifierCode String
  deviceName     String
  action         String
  occurredAt     DateTime         @default(now())
  createdAt      DateTime         @default(now())

  @@index([ownerId, module, occurredAt])
  @@index([deviceId, occurredAt])
  @@index([ownerId, occurredAt])
  @@map("service_history_events")
}

model FeedbackEvent {
  id        String           @id @default(uuid())
  ownerId   String
  owner     User             @relation("user_feedback_events", fields: [ownerId], references: [id], onDelete: Cascade)
  deviceId  String
  device    Device           @relation("device_feedback_events", fields: [deviceId], references: [id], onDelete: Restrict)
  sentiment FeedbackSentiment
  source    FeedbackSource   @default(BUTTON)
  comment   String?
  createdAt DateTime         @default(now())

  @@index([ownerId, deviceId, createdAt])
  @@index([deviceId, createdAt])
  @@index([ownerId, createdAt])
  @@map("feedback_events")
}

model Order {
  id              String          @id @default(uuid())
  customerId      String
  customer        User            @relation("user_orders", fields: [customerId], references: [id], onDelete: Restrict)
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  systemId        String
  system          BusinessSystem  @relation(fields: [systemId], references: [id], onDelete: Restrict)
  targetType      OrderTargetType
  quantity        Int
  unitPriceCents  Int?
  currency        String?
  idempotencyKey  String?
  status          OrderStatus     @default(CREATED)
  failureReason   String?
  allocations     Allocation[]
  stockMovements  StockMovement[]
  outboxEvents    OutboxEvent[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([customerId])
  @@index([tenantId])
  @@index([systemId])
  @@index([status])
  @@index([idempotencyKey])
  @@unique([customerId, idempotencyKey])
  @@map("orders")
}

model Allocation {
  id           String           @id @default(uuid())
  orderId      String
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId   String
  customer     User             @relation("user_allocations", fields: [customerId], references: [id], onDelete: Restrict)
  deviceId     String?
  device       Device?          @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  identifierId String?
  identifier   Identifier?      @relation(fields: [identifierId], references: [id], onDelete: SetNull)
  status       AllocationStatus @default(ASSIGNED)
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([deviceId])
  @@index([identifierId])
  @@index([status])
  @@map("allocations")
}

model StockMovement {
  id           String            @id @default(uuid())
  resourceType StockResourceType
  resourceId   String
  systemId     String
  system       BusinessSystem    @relation(fields: [systemId], references: [id], onDelete: Restrict)
  deviceId     String?
  device       Device?           @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  identifierId String?
  identifier   Identifier?       @relation(fields: [identifierId], references: [id], onDelete: SetNull)
  orderId      String?
  order        Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  action       StockMovementAction
  quantity     Int               @default(1)
  warehouseCode String?
  actorId      String?
  ownerId      String?
  fromStatus   String?
  toStatus     String?
  details      Json?
  createdAt    DateTime          @default(now())

  @@index([resourceType, resourceId])
  @@index([systemId, action])
  @@index([deviceId])
  @@index([identifierId])
  @@index([orderId])
  @@index([actorId])
  @@index([ownerId])
  @@index([warehouseCode])
  @@index([createdAt])
  @@map("stock_movements")
}

model OutboxEvent {
  id           String           @id @default(uuid())
  eventType    OutboxEventType
  status       OutboxEventStatus @default(PENDING)
  aggregateType String
  aggregateId  String
  tenantId     String?
  tenant       Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  systemId     String?
  system       BusinessSystem?  @relation(fields: [systemId], references: [id], onDelete: SetNull)
  orderId      String?
  order        Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  deviceId     String?
  device       Device?          @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  payload      Json
  attempts     Int              @default(0)
  availableAt  DateTime         @default(now())
  deliveredAt  DateTime?
  lastError    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([eventType, status])
  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@index([tenantId])
  @@index([systemId])
  @@index([orderId])
  @@index([deviceId])
  @@map("outbox_events")
}

model WebhookEndpoint {
  id              String   @id @default(uuid())
  name            String
  url             String
  secretEncrypted String?
  secretIv        String?
  secretTag       String?
  secretHash      String?
  events          Json
  isActive        Boolean  @default(true)
  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  failureCount    Int      @default(0)
  lastDeliveredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([tenantId])
  @@map("webhook_endpoints")
}

model AdminActionLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation("admin_action_logs", fields: [actorId], references: [id], onDelete: Restrict)
  action     String
  targetType String
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@map("admin_action_logs")
}
